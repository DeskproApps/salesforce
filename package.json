{
  "name": "@deskpro/app-salesforce",
  "version": "0.1.0",
  "description": "Deskpro integration with Salesforce",
  "main": "lib/main/javascript/index.js",
  "scripts": {
    "dev": "dpat server .",
    "package": "dpat clean . && dpat compile . && dpat bundle-installer . && dpat verify ./dist && dpat package .",
    "package-dev": "dpat bundle-installer . && dpat package .",
    "test": "dpat test ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DeskproApps/salesforce.git"
  },
  "keywords": [
    "deskpro",
    "salesforce integration"
  ],
  "author": {
    "name": "Deskpro Apps",
    "email": "apps@deskpro.com",
    "url": "https://www.deskpro.com"
  },
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/DeskproApps/salesforce/issues"
  },
  "homepage": "https://github.com/DeskproApps/salesforce#readme",
  "deskpro": {
    "version": "2.3.0",
    "title": "Salesforce",
    "isSingle": true,
    "scope": "agent",
    "targets": [
      {
        "target": "ticket-sidebar",
        "url": "html/index.html"
      }
    ],
    "storage": [
      {
        "name": "oauth:salesforce",
        "isBackendOnly": true,
        "permRead": "EVERYBODY",
        "permWrite": "OWNER"
      },
      {
        "name": "oauth:salesforce:access-token",
        "isBackendOnly": true,
        "permRead": "EVERYBODY",
        "permWrite": "EVERYBODY"
      },
      {
        "name": "oauth:salesforce:token",
        "isBackendOnly": true,
        "permRead": "EVERYBODY",
        "permWrite": "EVERYBODY"
      },
      {
        "name": "settings",
        "isBackendOnly": false,
        "permRead": "EVERYBODY",
        "permWrite": "OWNER"
      },
      {
        "name": "consumerKey",
        "isBackendOnly": false,
        "permRead": "OWNER",
        "permWrite": "OWNER"
      },
      {
        "name": "consumerSecret",
        "isBackendOnly": false,
        "permRead": "OWNER",
        "permWrite": "OWNER"
      }
    ],
    "settings": [
      {
        "name": "consumerKey",
        "defaultValue": "",
        "title": "The client id",
        "required": true,
        "type": "text"
      },
      {
        "name": "consumerSecret",
        "defaultValue": "",
        "title": "The client secret",
        "required": true,
        "type": "text"
      },
      {
        "name": "callbackUrl",
        "defaultValue": "",
        "title": "The connected app callback URL",
        "required": true,
        "type": "text"
      }
    ],
    "customFields": [],
    "deskproApiTags": [],
    "externalApis": [
      "/^https?://([^.]+\\.)*salesforce.com/?.*$/"
    ]
  },
  "devDependencies": {
    "@deskpro/apps-dpat": "^0.10.5",
    "@deskpro/apps-installer": "github:deskpro/apps-installer#v0.4.6",
    "@deskpro/apps-sdk-core": "^1.0.1",
    "@deskpro/apps-sdk-react": "^0.2.13",
    "@deskpro/react-components": "^1.3.24",
    "@deskpro/redux-components": "^1.0.3",
    "error-subclass": "2.2.0",
    "error-wrapper": "2.1.0",
    "prop-types": "^15.6.0",
    "react": "^15.6.1",
    "react-dom": "^15.6.1",
    "react-router": "^4.2.0",
    "react-select": "1.2.1",
    "react-test-renderer": "^15.6.1"
  }
}
